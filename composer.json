{
	"name": "rayhan-bapari/notyfyre",
	"description": "A modern, beautiful and highly customizable toast notification system for Laravel applications with extensive JavaScript API",
	"type": "library",
	"keywords": [
		"laravel",
		"notification",
		"toast",
		"alerts",
		"notyfyre",
		"popup",
		"messages",
		"flash",
		"javascript",
		"modern",
		"responsive"
	],
	"license": "MIT",
	"authors": [
		{
			"name": "Rayhan Bapari",
			"email": "rayhan.bapari@gmail.com",
			"homepage": "https://github.com/rayhan-bapari",
			"role": "Developer"
		}
	],
	"homepage": "https://github.com/rayhan-bapari/notyfyre",
	"support": {
		"issues": "https://github.com/rayhan-bapari/notyfyre/issues",
		"source": "https://github.com/rayhan-bapari/notyfyre"
	},
	"require": {
		"php": "^8.0|^8.1|^8.2|^8.3|^8.4",
		"illuminate/support": "^9.0|^10.0|^11.0|^12.0",
		"illuminate/view": "^9.0|^10.0|^11.0|^12.0",
		"illuminate/session": "^9.0|^10.0|^11.0|^12.0"
	},
	"require-dev": {
		"orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
		"phpunit/phpunit": "^9.5|^10.0|^11.0",
		"mockery/mockery": "^1.4",
		"phpstan/phpstan": "^1.0"
	},
	"autoload": {
		"psr-4": {
			"RayhanBapari\\Notyfyre\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"RayhanBapari\\Notyfyre\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"RayhanBapari\\Notyfyre\\NotyfyreServiceProvider"
			],
			"aliases": {
				"Notyfyre": "RayhanBapari\\Notyfyre\\Facades\\Notyfyre"
			}
		}
	},
	"scripts": {
		"test": "vendor/bin/phpunit",
		"test-coverage": "vendor/bin/phpunit --coverage-html coverage",
		"analyse": "vendor/bin/phpstan analyse",
		"format": "vendor/bin/php-cs-fixer fix"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"composer/package-versions-deprecated": true
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
