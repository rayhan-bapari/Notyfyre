{
	"name": "rayhan-bapari/notyfyre",
	"description": "A beautiful toast notification system for Laravel applications",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Rayhan Bapari",
			"email": "rayhan.bapari@example.com"
		}
	],
	"keywords": [
		"laravel",
		"notification",
		"toasts",
		"alerts",
		"notyfyre"
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^7.4|^8.0|^8.1|^8.2|^8.3|^8.4",
		"illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0"
	},
	"require-dev": {
		"orchestra/testbench": "^6.0|^7.0|^8.0|^9.0",
		"phpunit/phpunit": "^11.5"
	},
	"autoload": {
		"psr-4": {
			"RayhanBapari\\Notyfyre\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"RayhanBapari\\Notyfyre\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"RayhanBapari\\Notyfyre\\NotyfyreServiceProvider"
			],
			"aliases": {
				"Notyfyre": "RayhanBapari\\Notyfyre\\Facades\\Notyfyre"
			}
		}
	},
	"scripts": {
		"test": "vendor/bin/phpunit"
	},
	"config": {
		"sort-packages": true
	}
}
